{
  "manifest_version": 3,
  "name": "YouTube/Twitch Enhancer",
  "version": "4.5.1",
  "description": "Block channels, categories & keywords on YouTube & Twitch. Hide Shorts & watched videos, auto-claim points & drops, player tools.",

  "minimum_chrome_version": "111",

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "storage",
    "contextMenus"
  ],

  "host_permissions": [
    "*://www.youtube.com/*",
    "*://www.twitch.tv/*",
    "*://clips.twitch.tv/*",
    "*://api.betterttv.net/*",
    "*://api.frankerfacez.com/*",
    "*://7tv.io/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["src/page-quality.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["*://www.twitch.tv/*", "*://clips.twitch.tv/*"],
      "js": ["src/twitch.js"],
      "css": ["src/twitch.css"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["*://www.twitch.tv/*"],
      "js": ["src/page-twitch.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    }
  ],

  "background": {
    "service_worker": "src/background-sw.js"
  },

  "action": {
    "default_title": "YouTube/Twitch Enhancer",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  }
}
