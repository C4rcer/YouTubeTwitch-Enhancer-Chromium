{
  "manifest_version": 3,
  "name": "YouTube/Twitch Enhancer",
  "version": "4.8.1",
  "description": "Enhance YouTube & Twitch: block channels, categories, tags & keywords; hide Shorts/watched videos; add player, chat & claim tools.",

  "minimum_chrome_version": "111",

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "storage",
    "unlimitedStorage",
    "contextMenus"
  ],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.twitch.tv/*",
    "https://clips.twitch.tv/*",
    "https://sponsor.ajay.app/*",
    "https://returnyoutubedislikeapi.com/*",
    "https://api.betterttv.net/*",
    "https://api.frankerfacez.com/*",
    "https://7tv.io/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/watched-db.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/page-quality.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["https://www.twitch.tv/*", "https://clips.twitch.tv/*"],
      "js": ["src/twitch.js"],
      "css": ["src/twitch.css"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["src/page-twitch.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    }
  ],

  "background": {
    "service_worker": "src/background-sw.js"
  },

  "action": {
    "default_title": "YouTube/Twitch Enhancer",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  }
}
